# NeoCard Environment Configuration

APP_NAME=NeoCard
SECRET_KEY=replace-with-a-long-random-secret-key-min-32-chars
DEBUG=false
DATABASE_URL=sqlite:///./neocard.db

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:8000

# OpenAI (optional — AI works with smart fallbacks without key)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Admin emails (comma-separated, auto-promoted on Google login)
ADMIN_EMAILS=admin@example.com

# Rate limiting
RATE_LIMIT_PER_MINUTE=120

# Set to false only for local dev if SSL certificate errors occur
OAUTH_SSL_VERIFY=true
